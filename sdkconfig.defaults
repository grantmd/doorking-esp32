# Target and flash
CONFIG_IDF_TARGET="esp32c3"
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# XIAO ESP32-C3 exposes USB Serial/JTAG natively over its USB-C port.
# Route the console there so one cable does both power and logging.
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# Two OTA app slots + factory + NVS so we can do safe OTA updates later.
CONFIG_PARTITION_TABLE_TWO_OTA=y

# 1 kHz FreeRTOS tick gives us millisecond-granularity timers for the gate
# state machine (pulse width, travel timeouts, command throttling).
CONFIG_FREERTOS_HZ=1000

# Compiler: treat warnings as errors so bugs surface at build time.
CONFIG_COMPILER_WARN_WRITE_STRINGS=y

# Bump the esp_http_server request-header buffer from the 512 B default.
# Desktop browsers (Chrome/Safari/Firefox) routinely send 600+ bytes of
# headers on a plain form POST — User-Agent, Accept-*, Sec-*, Cookie,
# Upgrade-Insecure-Requests, etc. — and overflow the default, returning
# 431 before the handler ever runs. 2 KB is comfortable headroom.
CONFIG_HTTPD_MAX_REQ_HDR_LEN=2048
CONFIG_HTTPD_MAX_URI_LEN=1024
