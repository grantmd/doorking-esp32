# Common defaults shared across all supported targets. Target-specific
# options (flash size, console routing, USB mode) live in
# sdkconfig.defaults.<target> — ESP-IDF picks those up automatically
# based on whatever `idf.py set-target` was last run. Never pin
# CONFIG_IDF_TARGET here; it belongs to the set-target invocation.

# Partition layout: two 1700 KB OTA app slots, no factory partition.
#
# The built-in TWO_OTA layout gives only 1 MB per app slot, which the C5
# build was pushing uncomfortably close to after adding dual-band WiFi 6
# driver code. TWO_OTA_LARGE drops the "factory" fallback slot and grows
# each OTA slot to 1700 KB — a 70 % headroom increase per slot. The
# factory slot is only useful for commercial products where a firmware
# brick is a business problem; for a developer-owned gate controller
# where "plug in USB and reflash" is always 10 seconds away, it is
# zero-value storage. OTA still works exactly the same way: updates
# ping-pong between ota_0 and ota_1 and the bootloader can roll back
# between them.
#
# Fits cleanly on all three supported targets:
#   esp32c3: 4 MB flash  — ~3.4 MB partitioned, ~600 KB unused
#   esp32:  16 MB flash — ~3.4 MB partitioned, ~12 MB unused
#   esp32c5: 8 MB flash  — ~3.4 MB partitioned, ~4 MB unused
CONFIG_PARTITION_TABLE_TWO_OTA_LARGE=y

# 1 kHz FreeRTOS tick gives millisecond-granularity timers for the gate
# state machine (pulse width, travel timeouts, command throttling).
CONFIG_FREERTOS_HZ=1000

# Compiler: treat write-to-string-literal as an error, and optimise for
# size rather than debuggability. -Os (via CONFIG_COMPILER_OPTIMIZATION_SIZE)
# saves 10–25 % on most ESP-IDF builds compared to the default -Og, which
# matters because the C5's driver payload puts us uncomfortably close to
# the 1 MB app partition ceiling. Debug-build ergonomics (preserved stack
# frames, more inline symbols) are less important than runway for new
# features. Assertions stay enabled at the default level.
CONFIG_COMPILER_WARN_WRITE_STRINGS=y
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Bump the esp_http_server request-header buffer from the 512 B default.
# Desktop browsers (Chrome/Safari/Firefox) routinely send 600+ bytes of
# headers on a plain form POST — User-Agent, Accept-*, Sec-*, Cookie,
# Upgrade-Insecure-Requests, etc. — and overflow the default, returning
# 431 before the handler ever runs. 2 KB is comfortable headroom.
CONFIG_HTTPD_MAX_REQ_HDR_LEN=2048
CONFIG_HTTPD_MAX_URI_LEN=1024

# OTA rollback: after flashing a new image, the bootloader marks it as
# "pending verify". The firmware must call esp_ota_mark_app_valid() to
# commit. If it crashes or fails to connect within 120 s, the bootloader
# rolls back to the previous OTA slot on the next reboot.
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# mbedTLS content-length buffers. IN must stay at the 16 KB default because
# GitHub's CDN (Fastly) sends TLS records larger than 4 KB during OTA binary
# downloads — a smaller IN buffer causes MBEDTLS_ERR_SSL_UNEXPECTED_MESSAGE
# (-0x7100) to fire mid-stream. OUT can stay small since we only send tiny
# request headers; CONFIG_MBEDTLS_ASYMMETRIC_CONTENT_LEN lets IN and OUT
# differ, so we still save ~12 KB of heap over the fully-symmetric default.
# The mDNS-during-TLS-handshake log noise this previously tried to
# eliminate is now suppressed via esp_log_level_set in main.c instead.
CONFIG_MBEDTLS_ASYMMETRIC_CONTENT_LEN=y
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096
